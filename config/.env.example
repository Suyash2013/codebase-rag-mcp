# codebase-rag-mcp configuration
# All settings use the RAG_ prefix.
# Copy this file to .env and adjust as needed.

# --- Qdrant ---
# RAG_QDRANT_MODE=local          # "local" (on-disk, zero-config) | "remote" (Docker/cloud)
# RAG_QDRANT_LOCAL_PATH=          # Defaults to {working_dir}/.codebase-rag/qdrant
# RAG_QDRANT_HOST=localhost       # Remote Qdrant host
# RAG_QDRANT_PORT=6333            # Remote Qdrant port
# RAG_QDRANT_COLLECTION=codebase  # Qdrant collection name

# --- Embedding provider ---
# RAG_EMBEDDING_PROVIDER=onnx     # "onnx" | "ollama" | "openai" | "voyage"

# --- ONNX local embeddings (default, zero-config) ---
# RAG_ONNX_MODEL_NAME=all-MiniLM-L6-v2
# RAG_ONNX_MODEL_PATH=            # Defaults to {working_dir}/.codebase-rag/models/

# --- Ollama embeddings ---
# RAG_OLLAMA_BASE_URL=http://localhost:11434
# RAG_OLLAMA_EMBED_MODEL=snowflake-arctic-embed:latest

# --- OpenAI embeddings ---
# RAG_OPENAI_API_KEY=
# RAG_OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Voyage AI embeddings ---
# RAG_VOYAGE_API_KEY=
# RAG_VOYAGE_EMBED_MODEL=voyage-code-3

# --- Ingestion ---
# RAG_INGESTION_TIMEOUT_HOURS=24  # Re-index if older than this (hours)
# RAG_CHUNK_SIZE=1000             # Characters per chunk
# RAG_CHUNK_OVERLAP=200           # Overlap between chunks

# --- Search ---
# RAG_DEFAULT_N_RESULTS=10        # Default number of search results
# RAG_MAX_N_RESULTS=20            # Maximum number of search results

# --- Runtime ---
# RAG_WORKING_DIRECTORY=           # Override working directory (default: cwd)
