# Codebase RAG MCP Server Configuration
# Copy this file to .env and adjust values as needed.
# All variables are prefixed with RAG_.

# --- Qdrant Vector Database ---
# RAG_QDRANT_MODE=local  # "local" (on-disk, zero-config) or "remote" (Docker/cloud)
# RAG_QDRANT_LOCAL_PATH=  # Defaults to {working_dir}/.codebase-rag/qdrant
# RAG_QDRANT_HOST=localhost  # Only used when QDRANT_MODE=remote
# RAG_QDRANT_PORT=6333
# RAG_QDRANT_COLLECTION=codebase

# --- Embedding Provider ---
# RAG_EMBEDDING_PROVIDER=onnx  # "onnx" | "ollama" | "openai" | "voyage"

# ONNX (default, zero-config — auto-downloads all-MiniLM-L6-v2)
# RAG_ONNX_MODEL_NAME=all-MiniLM-L6-v2
# RAG_ONNX_MODEL_PATH=  # Defaults to {working_dir}/.codebase-rag/models/

# Ollama
# RAG_OLLAMA_BASE_URL=http://localhost:11434
# RAG_OLLAMA_EMBED_MODEL=snowflake-arctic-embed:latest

# OpenAI
# RAG_OPENAI_API_KEY=
# RAG_OPENAI_EMBED_MODEL=text-embedding-3-small

# Voyage AI
# RAG_VOYAGE_API_KEY=
# RAG_VOYAGE_EMBED_MODEL=voyage-code-3

# --- Ingestion ---
# RAG_INGESTION_TIMEOUT_HOURS=24
# RAG_CHUNK_SIZE=1000
# RAG_CHUNK_OVERLAP=200

# --- Search ---
# RAG_DEFAULT_N_RESULTS=10
# RAG_MAX_N_RESULTS=20

# --- Runtime ---
# RAG_WORKING_DIRECTORY=  # Defaults to current working directory
