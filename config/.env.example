# omni-rag-mcp configuration
# All settings use the OMNI_RAG_ prefix.
# Legacy RAG_ prefix is still supported with deprecation warnings.
# Copy this file to .env and adjust as needed.

# --- Qdrant ---
# OMNI_RAG_QDRANT_MODE=local          # "local" (on-disk, zero-config) | "remote" (Docker/cloud)
# OMNI_RAG_QDRANT_LOCAL_PATH=          # Defaults to {working_dir}/.omni-rag/qdrant
# OMNI_RAG_QDRANT_HOST=localhost       # Remote Qdrant host
# OMNI_RAG_QDRANT_PORT=6333            # Remote Qdrant port
# OMNI_RAG_QDRANT_COLLECTION=omni_rag  # Qdrant collection name

# --- Embedding provider ---
# OMNI_RAG_EMBEDDING_PROVIDER=onnx     # "onnx" | "ollama" | "openai" | "voyage"

# --- ONNX local embeddings (default, zero-config) ---
# OMNI_RAG_ONNX_MODEL_NAME=all-MiniLM-L6-v2
# OMNI_RAG_ONNX_MODEL_PATH=            # Defaults to {working_dir}/.omni-rag/models/

# --- Ollama embeddings ---
# OMNI_RAG_OLLAMA_BASE_URL=http://localhost:11434
# OMNI_RAG_OLLAMA_EMBED_MODEL=snowflake-arctic-embed:latest

# --- OpenAI embeddings ---
# OMNI_RAG_OPENAI_API_KEY=
# OMNI_RAG_OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Voyage AI embeddings ---
# OMNI_RAG_VOYAGE_API_KEY=
# OMNI_RAG_VOYAGE_EMBED_MODEL=voyage-code-3

# --- Ingestion ---
# OMNI_RAG_INGESTION_TIMEOUT_HOURS=24  # Re-index if older than this (hours)
# OMNI_RAG_CHUNK_SIZE=1000             # Characters per chunk
# OMNI_RAG_CHUNK_OVERLAP=200           # Overlap between chunks

# --- Search ---
# OMNI_RAG_DEFAULT_N_RESULTS=10        # Default number of search results
# OMNI_RAG_MAX_N_RESULTS=20            # Maximum number of search results
# OMNI_RAG_HYBRID_SEARCH_ENABLED=true  # Enable BM25+semantic hybrid search

# --- Features ---
# OMNI_RAG_ENABLE_CODE_PLUGIN=true     # Enable code-specific tools (signatures, dependency graph)

# --- Runtime ---
# OMNI_RAG_WORKING_DIRECTORY=           # Override working directory (default: cwd)
